# ============================================================
# Trading Co-Pilot — Backend Environment Variables
# Copy to .env and fill in your keys
# ============================================================

PORT=3001

# ── Supabase ─────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# (service role key bypasses RLS — keep secret, server-side only)

# ── Finnhub.io ───────────────────────────────────────────────
# Free tier: real-time WebSocket + company news
# Get key: https://finnhub.io (free)
FINNHUB_API_KEY=your_finnhub_key_here

# ── NewsAPI ──────────────────────────────────────────────────
# Breaking news, Trump posts, macro events
# Get key: https://newsapi.org (free: 100 req/day)
NEWS_API_KEY=your_newsapi_key_here

# ── Polygon.io ───────────────────────────────────────────────
# Professional market data (free tier available)
# Get key: https://polygon.io
POLYGON_API_KEY=your_polygon_key_here
